#!/usr/bin/env bash
# cc-auth [work [--daily-budget N]|personal|status|strip-global] [project-dir]
#
# Option-B per-project Claude Code auth switch. Confines the work API
# credentials (key + AWS external-Anthropic gateway base URL + workspace
# header) to a SINGLE repo's .claude/settings.local.json, so only that repo
# talks to the work gateway; every other repo falls back to your Claude.ai
# subscription (the global default).
#
#   work          stamp the work env block into <dir>/.claude/settings.local.json.
#                 --daily-budget N (or a bare number: `cc-auth work 50`) first sets
#                 WORK_DAILY_BUDGET — the $N/day cap enforced by the cc-work-limit
#                 hook and shown by the statusline `day` segment — in
#                 ~/.claude/work-auth.json as the GLOBAL work default (0 = disable);
#                 every future stamp in any repo inherits it
#   personal      strip the work env keys from that file (-> subscription default)
#   status        report what <dir> and the global settings currently use
#   strip-global  one-time: remove the work env block from ~/.claude/settings.local.json
#                 (backs up to *.bak first) so personal becomes the global default
#
# The statusline follows this same auth state automatically (a work-billed
# session shows the day/acct spend segments) — there is no separate display
# toggle. (cc-acct + ~/.claude/statusline-account were absorbed here.)
#
# The secret lives ONLY in ~/.claude/work-auth.json (chmod 600, never committed):
# a JSON object holding exactly the work `env` entries. This script copies it
# into the per-repo settings.local.json and keeps that file out of git via the
# repo's LOCAL .git/info/exclude (it never edits the tracked .gitignore). Which
# keys count as "work" is read from work-auth.json, so the block can grow/shrink
# without editing this script.
#
# Heads-up: starting Claude Code in a work repo prints
#   "Both claude.ai and ANTHROPIC_API_KEY set · auth may not work as expected".
# That is EXPECTED and harmless. Claude Code credential precedence puts
# ANTHROPIC_API_KEY (#3) ABOVE the subscription OAuth (#6), so the key wins and
# the gateway call uses it (the subscription can't reach a custom base URL
# anyway). Approve the key once when prompted to make it deliberate; check with
# /status. Do NOT /logout — that clears the subscription in every other repo.
#
# <project-dir> defaults to the git toplevel of the current directory (else cwd).
set -u

secret="$HOME/.claude/work-auth.json"
global="$HOME/.claude/settings.local.json"

die() { printf 'cc-auth: %s\n' "$*" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || die "jq is required"

cmd="${1:-status}"
(( $# > 0 )) && shift

# remaining args: --daily-budget N (or a bare number) sets the work daily
# budget; anything else is the project dir. A real dir is never purely numeric.
budget="" dir=""
while (( $# > 0 )); do
  case "$1" in
    --daily-budget)
      (( $# >= 2 )) || die "--daily-budget needs a value"
      budget="$2"; shift 2 ;;
    --daily-budget=*)
      budget="${1#*=}"; shift ;;
    *)
      if [[ "$1" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        budget="$1"
      else
        [[ -z "$dir" ]] || die "unexpected argument: $1"
        dir="$1"
      fi
      shift ;;
  esac
done
if [[ -n "$budget" ]]; then
  [[ "$budget" =~ ^[0-9]+(\.[0-9]+)?$ ]] \
    || die "invalid daily budget: '$budget' (must be a number in USD; 0 disables enforcement)"
  [[ "$cmd" == "work" ]] || die "--daily-budget only applies to 'work'"
fi

# resolve project dir: explicit arg, else git toplevel, else cwd
if [[ -z "$dir" ]]; then
  dir="$(git rev-parse --show-toplevel 2>/dev/null)"
  [[ -n "$dir" ]] || dir="$PWD"
fi
[[ -d "$dir" ]] || die "not a directory: $dir"
settings="$dir/.claude/settings.local.json"

require_secret() {
  [[ -f "$secret" ]] || die "missing $secret — a chmod 600 JSON object of the work env block"
  jq -e 'type=="object"' "$secret" >/dev/null 2>&1 || die "$secret must be a JSON object"
}

# keep a per-repo settings.local.json out of git via the LOCAL exclude only
ensure_excluded() {
  local top
  top="$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null)" || return 0
  git -C "$dir" check-ignore -q .claude/settings.local.json 2>/dev/null && return 0
  local ex="$top/.git/info/exclude"
  grep -qxF '.claude/settings.local.json' "$ex" 2>/dev/null \
    || printf '%s\n' '.claude/settings.local.json' >> "$ex"
}

# write stdin JSON to $1, atomically + chmod 600; delete the file if it is just {}
write_json() {
  local target="$1" tmp="$1.tmp.$$"
  mkdir -p "$(dirname "$target")"
  cat > "$tmp" || die "write failed: $target"
  if [[ "$(jq -c . "$tmp" 2>/dev/null)" == "{}" ]]; then
    rm -f "$tmp" "$target"
    echo "removed $target (now empty)"
    return 0
  fi
  chmod 600 "$tmp"
  mv "$tmp" "$target"
  chmod 600 "$target"
}

read_or_empty() { [[ -f "$1" ]] && cat "$1" || printf '{}'; }

# does file $1 carry the work keys?  mode all|any
has_work_keys() {  # $1=file  $2=all|any
  [[ -f "$1" && -f "$secret" ]] || return 1
  jq -e --slurpfile w "$secret" \
    "(.env // {}) as \$e | (\$w[0]|keys) as \$ks | $2(\$ks[]; \$e[.] != null)" \
    "$1" >/dev/null 2>&1
}

case "$cmd" in
  work)
    require_secret
    if [[ -n "$budget" ]]; then
      # string value: the Claude Code env block is all-strings by convention
      jq --arg b "$budget" '.WORK_DAILY_BUDGET = $b' "$secret" | write_json "$secret"
      echo "daily budget → \$$budget/day (global work default in $secret — every stamp inherits it)"
    fi
    if jq -e '[.[] | strings | select(test("REPLACE"))] | length > 0' "$secret" >/dev/null 2>&1; then
      die "$secret still has REPLACE placeholders — fill in the real work key/workspace id first"
    fi
    read_or_empty "$settings" \
      | jq --slurpfile w "$secret" '.env = ((.env // {}) + $w[0])' \
      | write_json "$settings"
    ensure_excluded
    echo "cc-auth work → $settings (this repo uses the work gateway)"
    echo "  • start a NEW Claude Code session for it to take effect (auth is read at startup)"
    echo "  • the 'Both claude.ai and ANTHROPIC_API_KEY set' warning is EXPECTED — the key wins by precedence; approve it once when prompted, confirm with /status"
    ;;

  personal)
    require_secret
    read_or_empty "$settings" \
      | jq --slurpfile w "$secret" '
          ($w[0]|keys) as $ks
          | .env = ((.env // {}) | delpaths($ks | map([.])))
          | if (.env | length) == 0 then del(.env) else . end' \
      | write_json "$settings"
    echo "cc-auth personal → $dir uses the Claude.ai subscription default"
    ;;

  strip-global)
    require_secret
    [[ -f "$global" ]] || { echo "no $global — subscription is already the global default"; exit 0; }
    cp "$global" "$global.bak" && chmod 600 "$global.bak"
    read_or_empty "$global" \
      | jq --slurpfile w "$secret" '
          ($w[0]|keys) as $ks
          | .env = ((.env // {}) | delpaths($ks | map([.])))
          | if (.env | length) == 0 then del(.env) else . end' \
      | write_json "$global"
    echo "stripped work creds from global (backup: $global.bak) → subscription is now the global default"
    echo "reminder: run '/login' once in Claude Code to ensure a personal subscription session exists"
    ;;

  status)
    echo "project: $dir"
    if [[ -f "$settings" ]]; then
      if has_work_keys "$settings" all; then
        echo "  $settings → work (gateway creds present)"
      else
        echo "  $settings → personal/other (no work creds)"
      fi
    else
      echo "  no .claude/settings.local.json → subscription default"
    fi
    if has_work_keys "$global" any; then
      echo "  ⚠ global $global still has work creds → forces work everywhere"
      echo "    run: ~/.scripts/cc-auth strip-global"
    else
      echo "  global default: Claude.ai subscription"
    fi
    if [[ -f "$secret" ]]; then
      gb=$(jq -r '.WORK_DAILY_BUDGET // empty' "$secret" 2>/dev/null)
      if [[ -n "$gb" ]]; then
        echo "  work daily budget: \$$gb/day (global default; 0 = enforcement disabled)"
      else
        echo "  work daily budget: unset → default \$100/day (set: cc-auth work --daily-budget N)"
      fi
      rb=$(jq -r '.env.WORK_DAILY_BUDGET // empty' "$settings" 2>/dev/null)
      if [[ -n "$rb" && "$rb" != "$gb" ]]; then
        echo "    ⚠ repo stamped with \$$rb/day — re-run 'cc-auth work' to sync"
      fi
    else
      echo "  (no $secret yet — 'work' needs it)"
    fi
    ;;

  -h|--help)
    sed -n '2,40p' "$0"
    ;;

  *)
    echo "usage: cc-auth [work [--daily-budget N]|personal|status|strip-global] [project-dir]" >&2
    exit 2
    ;;
esac
