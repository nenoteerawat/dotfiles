#!/usr/bin/env bash
# cc-acct [work|personal|auto|status]
#
# Chooses which account the Claude Code statusline shows API spend for.
#   auto      decide by repo: a pttep/work repo -> work, everything else -> personal
#   work      always show the work account
#   personal  always show the personal account (no Cost API on individual accounts,
#             so it renders as no data)
#   status    print the current setting (default)
#
# Just writes one word to ~/.claude/statusline-account; the statusline reads it.
set -u
f="$HOME/.claude/statusline-account"

case "${1:-status}" in
  work|personal|auto)
    mkdir -p "$(dirname "$f")"
    printf '%s\n' "$1" > "$f"
    echo "statusline account → $1"
    ;;
  status)
    s=$(cat "$f" 2>/dev/null)
    echo "statusline account: ${s:-auto (default)}"
    ;;
  -h|--help)
    echo "usage: cc-acct [work|personal|auto|status]"
    ;;
  *)
    echo "usage: cc-acct [work|personal|auto|status]" >&2
    exit 2
    ;;
esac
