#!/usr/bin/env bash
# cc-credits-refresh <account>   (default: work)
#
# Fetches month-to-date Anthropic API spend for an account from the Cost API
# and writes a small NON-SECRET JSON cache the statusline reads. This is the
# ONLY file that touches the Admin key.
#
# Security model:
#   - The Admin key lives in ~/.claude/statusline-credits.env (chmod 600,
#     never committed). This script sources it; the tracked statusline never
#     reads the key.
#   - The key is handed to curl via a stdin config (`-K -`), so it never
#     appears in argv / `ps` output. printf is the bash builtin (no argv).
#   - The cache holds only derived numbers (spent, budget, pct) — no secret.
#
# Cost/usage requires an Admin key (sk-ant-admin01-...). A regular key
# (sk-ant-api...) is rejected by the endpoint, so we don't even send it.
#
# Safe to run on a timer or to be spawned in the background by the statusline.
# A lock (stolen if older than 120s) prevents concurrent fetches piling up.

set -u

acct="${1:-work}"
cfg="$HOME/.claude/statusline-credits.env"
cache_dir="$HOME/.claude/cache"
cache="$cache_dir/credits-${acct}.json"
lock="$cache_dir/credits-${acct}.lock"
mkdir -p "$cache_dir"

now=$(date +%s)

# write <status> <spent> <budget> <pct> [msg]
write() {
  command -v jq >/dev/null 2>&1 || return 0
  local tmp="$cache.tmp.$$"
  jq -n \
    --arg     a "$acct" \
    --arg     s "$1" \
    --argjson sp "${2:-0}" \
    --argjson b  "${3:-0}" \
    --argjson p  "${4:-0}" \
    --arg     m  "${5:-}" \
    --argjson t  "$now" \
    '{account:$a,status:$s,spent:$sp,budget:$b,pct:$p,msg:$m,fetched_at:$t}' \
    > "$tmp" 2>/dev/null && mv "$tmp" "$cache"
}

# --- lock: skip if another fetch is in flight (steal a stale lock > 120s) ---
if ! mkdir "$lock" 2>/dev/null; then
  lk=$(stat -f %m "$lock" 2>/dev/null || stat -c %Y "$lock" 2>/dev/null || echo 0)
  [[ "$lk" =~ ^[0-9]+$ ]] || lk=0
  (( now - lk < 120 )) && exit 0
  rmdir "$lock" 2>/dev/null; mkdir "$lock" 2>/dev/null || exit 0
fi
trap 'rmdir "$lock" 2>/dev/null' EXIT

command -v jq   >/dev/null 2>&1 || exit 0
command -v curl >/dev/null 2>&1 || { write error 0 0 0 "curl not installed"; exit 0; }

# --- config / key (only read the fields we expect) ---
[[ -f "$cfg" ]] || { write no_key 0 0 0 "no ~/.claude/statusline-credits.env"; exit 0; }
WORK_ADMIN_KEY=""; WORK_MONTHLY_BUDGET=""
# shellcheck disable=SC1090
. "$cfg" 2>/dev/null

KEY=""; BUDGET=0
if [[ "$acct" == "work" ]]; then KEY="$WORK_ADMIN_KEY"; BUDGET="${WORK_MONTHLY_BUDGET:-0}"; fi
[[ "$BUDGET" =~ ^[0-9]+(\.[0-9]+)?$ ]] || BUDGET=0

case "$KEY" in
  ""|*REPLACE*|*your-admin-key*)  write no_key 0 "$BUDGET" 0 "set WORK_ADMIN_KEY (sk-ant-admin01-...)"; exit 0 ;;
  sk-ant-api*)                    write no_key 0 "$BUDGET" 0 "that is a regular key; need an Admin key"; exit 0 ;;
  sk-ant-admin*)                  : ;;   # looks like an Admin key
  *)                              write no_key 0 "$BUDGET" 0 "key does not look like an Admin key"; exit 0 ;;
esac

# --- month-to-date range, UTC: first of month -> start of tomorrow ---
# (%Y-%m-01 works on both BSD and GNU date; the tomorrow calc differs.)
start=$(date -u +%Y-%m-01T00:00:00Z)
end=$(date -u -v+1d +%Y-%m-%dT00:00:00Z 2>/dev/null \
   || date -u -d tomorrow +%Y-%m-%dT00:00:00Z 2>/dev/null)
[[ -n "$end" ]] || end=$(date -u +%Y-%m-%dT23:59:59Z)

# --- fetch (key via stdin config -> never in argv); sum amount (cents) ---
cents=0; page=""; ok=1
for _ in 1 2 3 4 5; do   # paginate defensively; a month of daily buckets is ~1 page
  resp=$(printf 'header = "x-api-key: %s"\nheader = "anthropic-version: 2023-06-01"\n' "$KEY" \
    | curl -sS --max-time 10 -G "https://api.anthropic.com/v1/organizations/cost_report" \
        --data-urlencode "starting_at=$start" \
        --data-urlencode "ending_at=$end" \
        --data-urlencode "bucket_width=1d" \
        --data-urlencode "limit=31" \
        ${page:+--data-urlencode "page=$page"} \
        -K - 2>/dev/null)
  [[ -z "$resp" ]] && { ok=0; break; }
  if printf '%s' "$resp" | jq -e '.type=="error" or (.error!=null)' >/dev/null 2>&1; then
    msg=$(printf '%s' "$resp" | jq -r '.error.message // "cost API error"' 2>/dev/null)
    write error 0 "$BUDGET" 0 "$msg"; exit 0
  fi
  c=$(printf '%s' "$resp" | jq -r '[.data[].results[].amount | tonumber] | add // 0' 2>/dev/null)
  [[ "$c" =~ ^[0-9]+(\.[0-9]+)?$ ]] || { ok=0; break; }
  cents=$(awk -v a="$cents" -v b="$c" 'BEGIN{printf "%.6f", a+b}')
  more=$(printf '%s' "$resp" | jq -r '.has_more // false' 2>/dev/null)
  page=$(printf '%s' "$resp" | jq -r '.next_page // ""' 2>/dev/null)
  [[ "$more" == "true" && -n "$page" ]] || break
done

(( ok )) || { write error 0 "$BUDGET" 0 "cost API request failed"; exit 0; }

spent=$(awk -v c="$cents" 'BEGIN{printf "%.2f", c/100}')
pct=0
if awk -v b="$BUDGET" 'BEGIN{exit !(b>0)}'; then
  pct=$(awk -v s="$spent" -v b="$BUDGET" 'BEGIN{printf "%.0f", (s/b)*100}')
fi
write ok "$spent" "$BUDGET" "$pct" ""
