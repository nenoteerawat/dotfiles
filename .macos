#!/usr/bin/env bash

# ~/.macos — minimal macOS setup
#
# Philosophy: keep the system at macOS defaults and encode ONLY the deliberate
# deltas this machine actually uses. This is a snapshot of the real machine
# (taken 2026-06-30 on macOS 26 "Tahoe"), NOT the upstream craftzdog/mathiasbynens
# kitchen-sink — that 978-line version (Safari/Mail/Dock opinions, Twitter,
# Transmission, Opera, SizeUp, … for apps not installed here) was replaced and
# lives in git history if it is ever needed again.
#
# Re-running is idempotent and never drags in opinions for apps you don't use.
# It needs NO sudo (there are no system-level writes).
#
# Apply:        ./.macos      (then log out / in for language/region to take).
#               Spotlight's ⌥ Space hotkey is scripted but on macOS 26 may need a
#               one-time System Settings toggle to go live; Alfred's ⌘ Space hotkey
#               is GUI-only — see the "Launcher hotkeys" section below.
# Re-snapshot:  changed something in System Settings and want to keep it? Read it
#               with `defaults read <domain> <key>` and add a line in the matching
#               section below. Keep this file a faithful mirror of your real deltas.

# Close System Settings so it can't overwrite values we're about to change.
osascript -e 'tell application "System Settings" to quit' 2>/dev/null

###############################################################################
# Language & region — English (Thailand) + Thai                               #
###############################################################################
# Snapshot: AppleLocale=en_TH, AppleLanguages=(en-TH, th-TH). The en_TH locale
# already implies metric units / Celsius / local formats, so nothing else here.
defaults write NSGlobalDomain AppleLanguages -array "en-TH" "th-TH"
defaults write NSGlobalDomain AppleLocale -string "en_TH"

###############################################################################
# Trackpad — tap to click                                                     #
###############################################################################
# Snapshot: Clicking = true on both the built-in and Bluetooth trackpad domains
# (this is what the Settings UI writes when you enable "Tap to click").
defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad Clicking -bool true

###############################################################################
# Launcher hotkeys — Alfred on ⌘ Space, Spotlight on ⌥ Space                  #
###############################################################################
# Spotlight side (snapshot): rebind "Show Spotlight search" (symbolichotkeys id 64)
# from its ⌘ Space default to ⌥ Space — records ⌥ Space and frees ⌘ Space for
# Alfred (the primary launcher).
#   parameters = (ascii, keycode, modifiers); 32 = space char, 49 = space keycode.
#   modifier masks (additive): ⌘ = 1048576, ⌥ = 524288, ⌃ = 262144, ⇧ = 131072.
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 64 \
	"{ enabled = 1; value = { parameters = ( 32, 49, 524288 ); type = standard; }; }"
# Flush cfprefsd's in-memory cache, then force-rebind all symbolic hotkeys.
killall cfprefsd 2>/dev/null
"/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings" -u
# TAHOE (macOS 26) CAVEAT: the line above WRITES the right value (verify with
# `defaults read com.apple.symbolichotkeys AppleSymbolicHotKeys 64`), but the
# running Spotlight may not pick it up — ⌘ Space can keep opening Spotlight even
# after a reboot. If so, toggle it ONCE by hand to make it live: System Settings →
# Keyboard → Keyboard Shortcuts → Spotlight → record ⌥ Space for "Show Spotlight
# search". The write above then just keeps that state.
#
# Alfred → ⌘ Space is GUI-only (cannot be scripted at all): the hotkey is a
# machine-local, non-synced setting inside the Alfred.alfredpreferences bundle
# (preferences/local/<machine-hash>/). Set it in Alfred Settings → General →
# Hotkey → press ⌘ Space. Then confirm ⌘ Space isn't also claimed by Input
# Sources (⌃ Space default) or Dictation under System Settings → Keyboard.

echo "Done. Log out / in to apply language/region."
echo "Spotlight ⌥ Space is written, but on macOS 26 may need a one-time System"
echo "Settings toggle to go live; set Alfred to ⌘ Space by hand (see comments above)."
