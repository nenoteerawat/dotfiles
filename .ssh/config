Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/personal_gh_id
    IdentitiesOnly yes

# PTTEP work account — used for the pttep-pcl and pttep-fusionsol orgs.
# Reached via the git@github.com-pttep:<org>/<repo> form (see url.insteadOf in ~/.gitconfig).
Host github.com-pttep
    HostName github.com
    User git
    IdentityFile ~/.ssh/pttep_gh_id
    IdentitiesOnly yes
